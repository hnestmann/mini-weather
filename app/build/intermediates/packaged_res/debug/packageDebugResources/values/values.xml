<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="background">#FFFFFF</color>
    <color name="foreground">#000000</color>
    <dimen name="screen_height">800dp</dimen>
    <dimen name="screen_width">600dp</dimen>
    <string name="app_name">Mini Weather</string>
    <style name="Theme.MiniWeather" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:colorPrimary">@color/foreground</item>
        <item name="android:textColorPrimary">@color/foreground</item>
        <item name="android:windowNoTitle">true</item>
    </style>
</resources>